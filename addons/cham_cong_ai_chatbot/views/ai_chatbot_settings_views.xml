<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_ai_chatbot" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ai.chatbot</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="AI Chatbot"
                     string="AI Chatbot" data-key="cham_cong_ai_chatbot">
                    <h2>AI Chatbot Nhân sự</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_chatbot_enable_openai"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_chatbot_enable_openai"/>
                                <div class="text-muted">Bật tích hợp OpenAI cho chatbot</div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_chatbot_enable_fc"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_chatbot_enable_fc"/>
                                <div class="text-muted">Cho phép AI gọi function</div>
                            </div>
                        </div>
                    </div>
                    <h3>Kết nối OpenAI</h3>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 o_setting_box">
                            <div class="o_setting_right_pane">
                                <label for="ai_chatbot_api_key"/>
                                <field name="ai_chatbot_api_key" password="True"/>
                                <label for="ai_chatbot_base_url" class="mt8"/>
                                <field name="ai_chatbot_base_url"/>
                                <label for="ai_chatbot_model" class="mt8"/>
                                <field name="ai_chatbot_model"/>
                                <label for="ai_chatbot_timeout" class="mt8"/>
                                <field name="ai_chatbot_timeout"/>
                            </div>
                        </div>
                    </div>
                    <h3>Hành động &amp; Xác nhận</h3>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_chatbot_enable_confirm"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_chatbot_enable_confirm"/>
                                <div class="text-muted">Yêu cầu xác nhận trước khi thực hiện</div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_chatbot_allow_create_attendance"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_chatbot_allow_create_attendance"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_chatbot_allow_update_attendance"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_chatbot_allow_update_attendance"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_chatbot_allow_create_leave"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_chatbot_allow_create_leave"/>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_chatbot_allow_print_payroll"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_chatbot_allow_print_payroll"/>
                            </div>
                        </div>
                    </div>
                    <h3>Khác</h3>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_chatbot_use_fallback"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_chatbot_use_fallback"/>
                                <div class="text-muted">Dùng xử lý rule-based khi OpenAI lỗi</div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="ai_chatbot_save_history"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="ai_chatbot_save_history"/>
                                <div class="text-muted">Lưu lịch sử hội thoại</div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_ai_chatbot_config_settings" model="ir.actions.act_window">
        <field name="name">Cấu hình Chatbot</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'cham_cong_ai_chatbot'}</field>
    </record>
</odoo>
