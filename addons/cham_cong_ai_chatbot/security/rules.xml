<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_ai_chat_session_own" model="ir.rule">
            <field name="name">Phiên chat: chỉ của mình</field>
            <field name="model_id" ref="model_ai_chat_session"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ai_chatbot_employee_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_ai_chat_session_manager" model="ir.rule">
            <field name="name">Phiên chat: quản lý xem tất cả</field>
            <field name="model_id" ref="model_ai_chat_session"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[
                (4, ref('group_ai_chatbot_manager')),
                (4, ref('cham_cong_tinh_luong.group_cham_cong_nhan_su')),
                (4, ref('cham_cong_tinh_luong.group_cham_cong_quan_tri'))
            ]"/>
        </record>

        <record id="rule_ai_chat_message_own" model="ir.rule">
            <field name="name">Tin nhắn: chỉ trong phiên của mình</field>
            <field name="model_id" ref="model_ai_chat_message"/>
            <field name="domain_force">[('session_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ai_chatbot_employee_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_ai_chat_message_manager" model="ir.rule">
            <field name="name">Tin nhắn: quản lý xem tất cả</field>
            <field name="model_id" ref="model_ai_chat_message"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[
                (4, ref('group_ai_chatbot_manager')),
                (4, ref('cham_cong_tinh_luong.group_cham_cong_nhan_su')),
                (4, ref('cham_cong_tinh_luong.group_cham_cong_quan_tri'))
            ]"/>
        </record>

        <record id="rule_ai_chat_action_log_own" model="ir.rule">
            <field name="name">Log hành động: chỉ của mình</field>
            <field name="model_id" ref="model_ai_chat_action_log"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ai_chatbot_employee_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_ai_chat_action_log_manager" model="ir.rule">
            <field name="name">Log hành động: quản lý xem tất cả</field>
            <field name="model_id" ref="model_ai_chat_action_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[
                (4, ref('group_ai_chatbot_manager')),
                (4, ref('cham_cong_tinh_luong.group_cham_cong_nhan_su')),
                (4, ref('cham_cong_tinh_luong.group_cham_cong_quan_tri'))
            ]"/>
        </record>
    </data>
</odoo>
