<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         TREE
    ============================================================ -->
    <record id="view_van_ban_di_tree" model="ir.ui.view">
        <field name="name">van.ban.di.tree</field>
        <field name="model">van_ban_di</field>
        <field name="arch" type="xml">
            <tree string="Văn bản đi"
                  decoration-muted="trang_thai == 'du_thao'"
                  decoration-warning="trang_thai == 'cho_ky'"
                  decoration-info="trang_thai == 'da_ky'"
                  decoration-success="trang_thai == 'da_phat_hanh'"
                  decoration-primary="trang_thai == 'luu_tru'">
                <field name="so_van_ban_di"/>
                <field name="so_hieu_van_ban"/>
                <field name="ten_van_ban"/>
                <field name="loai_van_ban_id"/>
                <field name="ngay_phat_hanh"/>
                <field name="don_vi_soan_thao_id"/>
                <field name="nguoi_ky_id"/>
                <field name="noi_nhan"/>
                <field name="do_khan"/>
                <field name="trang_thai"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================
         FORM
    ============================================================ -->
    <record id="view_van_ban_di_form" model="ir.ui.view">
        <field name="name">van.ban.di.form</field>
        <field name="model">van_ban_di</field>
        <field name="arch" type="xml">
            <form string="Văn bản đi">
                <header>
                    <button name="action_cho_ky"
                            type="object"
                            string="Chuyển chờ ký"
                            class="btn-primary"
                            attrs="{'invisible': [('trang_thai', '!=', 'du_thao')]}"/>
                    <button name="action_da_ky"
                            type="object"
                            string="Đã ký"
                            class="btn-primary"
                            attrs="{'invisible': [('trang_thai', '!=', 'cho_ky')]}"/>
                    <button name="action_phat_hanh"
                            type="object"
                            string="Phát hành"
                            class="btn-success"
                            attrs="{'invisible': [('trang_thai', '!=', 'da_ky')]}"/>
                    <button name="action_luu_tru"
                            type="object"
                            string="Lưu trữ"
                            attrs="{'invisible': [('trang_thai', 'in', ['du_thao','luu_tru'])]}"/>
                    <field name="trang_thai"
                           widget="statusbar"
                           statusbar_visible="du_thao,cho_ky,da_ky,da_phat_hanh,luu_tru"/>
                </header>
                <sheet>
                    <group string="Thông tin văn bản">
                        <group>
                            <field name="so_van_ban_di"/>
                            <field name="so_hieu_van_ban"/>
                            <field name="ten_van_ban"/>
                            <field name="loai_van_ban_id"/>
                        </group>
                        <group>
                            <field name="ngay_phat_hanh"/>
                            <field name="do_mat"/>
                            <field name="do_khan"/>
                        </group>
                    </group>
                    <group string="Thông tin phát hành">
                        <group>
                            <field name="don_vi_soan_thao_id"/>
                            <field name="nguoi_ky_id"
                                   domain="[('phong_ban_id', '=', don_vi_soan_thao_id)]"/>
                        </group>
                        <group>
                            <field name="noi_nhan"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Trích yếu">
                            <field name="trich_yeu"/>
                        </page>
                        <page string="Ghi chú">
                            <field name="ghi_chu"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         SEARCH
    ============================================================ -->
    <record id="view_van_ban_di_search" model="ir.ui.view">
        <field name="name">van.ban.di.search</field>
        <field name="model">van_ban_di</field>
        <field name="arch" type="xml">
            <search string="Tìm văn bản đi">
                <field name="so_van_ban_di"/>
                <field name="so_hieu_van_ban"/>
                <field name="ten_van_ban"/>
                <field name="don_vi_soan_thao_id"/>
                <field name="nguoi_ky_id"/>
                <separator/>
                <filter string="Dự thảo" name="filter_du_thao" domain="[('trang_thai','=','du_thao')]"/>
                <filter string="Chờ ký" name="filter_cho_ky" domain="[('trang_thai','=','cho_ky')]"/>
                <filter string="Đã ký" name="filter_da_ky" domain="[('trang_thai','=','da_ky')]"/>
                <filter string="Đã phát hành" name="filter_da_phat_hanh" domain="[('trang_thai','=','da_phat_hanh')]"/>
                <filter string="Lưu trữ" name="filter_luu_tru" domain="[('trang_thai','=','luu_tru')]"/>
                <separator/>
                <filter string="Độ khẩn" name="filter_khan" domain="[('do_khan','!=','thuong')]"/>
                <filter string="Mật" name="filter_mat" domain="[('do_mat','!=','thuong')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Đơn vị soạn thảo" name="group_don_vi" context="{'group_by':'don_vi_soan_thao_id'}"/>
                    <filter string="Người ký" name="group_nguoi_ky" context="{'group_by':'nguoi_ky_id'}"/>
                    <filter string="Trạng thái" name="group_trang_thai" context="{'group_by':'trang_thai'}"/>
                    <filter string="Loại văn bản" name="group_loai" context="{'group_by':'loai_van_ban_id'}"/>
                    <filter string="Tháng phát hành" name="group_thang" context="{'group_by':'ngay_phat_hanh:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         ACTIONS
    ============================================================ -->
    <record id="action_van_ban_di" model="ir.actions.act_window">
        <field name="name">Văn bản đi</field>
        <field name="res_model">van_ban_di</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_van_ban_di_search"/>
    </record>

    <record id="action_van_ban_di_cho_ky" model="ir.actions.act_window">
        <field name="name">Văn bản chờ ký</field>
        <field name="res_model">van_ban_di</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('trang_thai','=','cho_ky')]</field>
        <field name="search_view_id" ref="view_van_ban_di_search"/>
    </record>

    <record id="action_van_ban_di_da_phat_hanh" model="ir.actions.act_window">
        <field name="name">Văn bản đã phát hành</field>
        <field name="res_model">van_ban_di</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('trang_thai','=','da_phat_hanh')]</field>
        <field name="search_view_id" ref="view_van_ban_di_search"/>
    </record>
</odoo>
