<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         TREE
    ============================================================ -->
    <record id="view_van_ban_den_tree" model="ir.ui.view">
        <field name="name">van.ban.den.tree</field>
        <field name="model">van_ban_den</field>
        <field name="arch" type="xml">
            <tree string="Văn bản đến"
                  decoration-info="trang_thai == 'moi'"
                  decoration-primary="trang_thai == 'vao_so'"
                  decoration-warning="trang_thai == 'dang_xu_ly'"
                  decoration-success="trang_thai == 'da_xu_ly'"
                  decoration-muted="trang_thai == 'luu_tru'">
                <field name="so_van_ban_den"/>
                <field name="so_hieu_van_ban"/>
                <field name="ten_van_ban"/>
                <field name="loai_van_ban_id"/>
                <field name="ngay_den"/>
                <field name="co_quan_ban_hanh"/>
                <field name="don_vi_nhan_id"/>
                <field name="nhan_vien_xu_ly_id"/>
                <field name="han_xu_ly"/>
                <field name="do_khan"/>
                <field name="trang_thai"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================
         FORM
    ============================================================ -->
    <record id="view_van_ban_den_form" model="ir.ui.view">
        <field name="name">van.ban.den.form</field>
        <field name="model">van_ban_den</field>
        <field name="arch" type="xml">
            <form string="Văn bản đến">
                <header>
                    <button name="action_vao_so"
                            type="object"
                            string="Vào sổ"
                            class="btn-primary"
                            attrs="{'invisible': [('trang_thai', '!=', 'moi')]}"/>
                    <button name="action_chuyen_xu_ly"
                            type="object"
                            string="Chuyển xử lý"
                            class="btn-primary"
                            attrs="{'invisible': [('trang_thai', 'not in', ['moi', 'vao_so'])]}"/>
                    <button name="action_da_xu_ly"
                            type="object"
                            string="Đã xử lý"
                            class="btn-success"
                            attrs="{'invisible': [('trang_thai', '!=', 'dang_xu_ly')]}"/>
                    <button name="action_luu_tru"
                            type="object"
                            string="Lưu trữ"
                            attrs="{'invisible': [('trang_thai', 'in', ['luu_tru'])]}"/>
                    <field name="trang_thai"
                           widget="statusbar"
                           statusbar_visible="moi,vao_so,dang_xu_ly,da_xu_ly,luu_tru"/>
                </header>
                <sheet>
                    <group string="Thông tin văn bản">
                        <group>
                            <field name="so_van_ban_den"/>
                            <field name="so_hieu_van_ban"/>
                            <field name="ten_van_ban"/>
                            <field name="loai_van_ban_id"/>
                            <field name="co_quan_ban_hanh"/>
                        </group>
                        <group>
                            <field name="ngay_den"/>
                            <field name="ngay_ban_hanh"/>
                            <field name="do_mat"/>
                            <field name="do_khan"/>
                        </group>
                    </group>
                    <group string="Xử lý văn bản">
                        <group>
                            <field name="don_vi_nhan_id"/>
                            <field name="nhan_vien_xu_ly_id"
                                   domain="[('phong_ban_id', '=', don_vi_nhan_id)]"/>
                        </group>
                        <group>
                            <field name="han_xu_ly"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Trích yếu">
                            <field name="trich_yeu"/>
                        </page>
                        <page string="Ghi chú">
                            <field name="ghi_chu"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ============================================================
         SEARCH
    ============================================================ -->
    <record id="view_van_ban_den_search" model="ir.ui.view">
        <field name="name">van.ban.den.search</field>
        <field name="model">van_ban_den</field>
        <field name="arch" type="xml">
            <search string="Tìm văn bản đến">
                <field name="so_van_ban_den"/>
                <field name="so_hieu_van_ban"/>
                <field name="ten_van_ban"/>
                <field name="co_quan_ban_hanh"/>
                <field name="don_vi_nhan_id"/>
                <field name="nhan_vien_xu_ly_id"/>
                <separator/>
                <filter string="Mới" name="filter_moi" domain="[('trang_thai','=','moi')]"/>
                <filter string="Đã vào sổ" name="filter_vao_so" domain="[('trang_thai','=','vao_so')]"/>
                <filter string="Đang xử lý" name="filter_dang_xu_ly" domain="[('trang_thai','=','dang_xu_ly')]"/>
                <filter string="Đã xử lý" name="filter_da_xu_ly" domain="[('trang_thai','=','da_xu_ly')]"/>
                <filter string="Lưu trữ" name="filter_luu_tru" domain="[('trang_thai','=','luu_tru')]"/>
                <separator/>
                <filter string="Quá hạn" name="filter_qua_han"
                        domain="[('han_xu_ly','&lt;', context_today()), ('trang_thai','not in', ['da_xu_ly','luu_tru'])]"/>
                <filter string="Hôm nay" name="filter_hom_nay"
                        domain="[('ngay_den','=', context_today())]"/>
                <separator/>
                <filter string="Độ khẩn" name="filter_khan"
                        domain="[('do_khan','!=','thuong')]"/>
                <filter string="Mật" name="filter_mat"
                        domain="[('do_mat','!=','thuong')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Đơn vị nhận" name="group_don_vi_nhan" context="{'group_by':'don_vi_nhan_id'}"/>
                    <filter string="Người xử lý" name="group_nhan_vien_xu_ly" context="{'group_by':'nhan_vien_xu_ly_id'}"/>
                    <filter string="Trạng thái" name="group_trang_thai" context="{'group_by':'trang_thai'}"/>
                    <filter string="Loại văn bản" name="group_loai" context="{'group_by':'loai_van_ban_id'}"/>
                    <filter string="Ngày đến" name="group_ngay_den" context="{'group_by':'ngay_den:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         ACTIONS
    ============================================================ -->
    <record id="action_van_ban_den" model="ir.actions.act_window">
        <field name="name">Văn bản đến</field>
        <field name="res_model">van_ban_den</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_van_ban_den_search"/>
    </record>

    <record id="action_van_ban_den_dang_xu_ly" model="ir.actions.act_window">
        <field name="name">Văn bản đang xử lý</field>
        <field name="res_model">van_ban_den</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('trang_thai','in',['moi','vao_so','dang_xu_ly'])]</field>
        <field name="search_view_id" ref="view_van_ban_den_search"/>
    </record>

    <record id="action_van_ban_den_qua_han" model="ir.actions.act_window">
        <field name="name">Văn bản quá hạn</field>
        <field name="res_model">van_ban_den</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('han_xu_ly','&lt;', fields.Date.today()), ('trang_thai','not in',['da_xu_ly','luu_tru'])]</field>
        <field name="context">{'search_default_filter_qua_han': 1}</field>
        <field name="search_view_id" ref="view_van_ban_den_search"/>
    </record>
</odoo>
