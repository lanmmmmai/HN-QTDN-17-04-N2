<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_van_ban_den_tree" model="ir.ui.view">
        <field name="name">van.ban.den.tree</field>
        <field name="model">van_ban_den</field>
        <field name="arch" type="xml">
            <tree string="Văn bản đến"
                  decoration-info="trang_thai == 'moi'"
                  decoration-warning="trang_thai == 'dang_xu_ly'"
                  decoration-success="trang_thai == 'da_xu_ly'">
                <field name="so_van_ban_den"/>
                <field name="so_hieu_van_ban"/>
                <field name="ten_van_ban"/>
                <field name="loai_van_ban_id"/>
                <field name="ngay_den"/>
                <field name="don_vi_nhan_id"/>
                <field name="nhan_vien_xu_ly_id"/>
                <field name="han_xu_ly"/>
                <field name="trang_thai"/>
            </tree>
        </field>
    </record>

    <record id="view_van_ban_den_form" model="ir.ui.view">
        <field name="name">van.ban.den.form</field>
        <field name="model">van_ban_den</field>
        <field name="arch" type="xml">
            <form string="Văn bản đến">
                <sheet>
                    <group string="Thông tin văn bản">
                        <group>
                            <field name="so_van_ban_den"/>
                            <field name="so_hieu_van_ban"/>
                            <field name="ten_van_ban"/>
                            <field name="loai_van_ban_id"/>
                        </group>
                        <group>
                            <field name="ngay_den"/>
                            <field name="ngay_ban_hanh"/>
                            <field name="co_quan_ban_hanh"/>
                            <field name="trang_thai"/>
                        </group>
                    </group>
                    <group string="Xử lý văn bản">
                        <group>
                            <field name="don_vi_nhan_id"/>
                            <field name="nhan_vien_xu_ly_id"/>
                        </group>
                        <group>
                            <field name="han_xu_ly"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Trích yếu">
                            <field name="trich_yeu"/>
                        </page>
                        <page string="Ghi chú">
                            <field name="ghi_chu"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_van_ban_den_search" model="ir.ui.view">
        <field name="name">van.ban.den.search</field>
        <field name="model">van_ban_den</field>
        <field name="arch" type="xml">
            <search string="Tìm văn bản đến">
                <field name="so_van_ban_den"/>
                <field name="so_hieu_van_ban"/>
                <field name="ten_van_ban"/>
                <field name="don_vi_nhan_id"/>
                <field name="nhan_vien_xu_ly_id"/>
                <filter string="Mới" name="filter_moi" domain="[('trang_thai','=','moi')]"/>
                <filter string="Đang xử lý" name="filter_dang_xu_ly" domain="[('trang_thai','=','dang_xu_ly')]"/>
                <filter string="Đã xử lý" name="filter_da_xu_ly" domain="[('trang_thai','=','da_xu_ly')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter string="Đơn vị nhận" name="group_don_vi" context="{'group_by':'don_vi_nhan_id'}"/>
                    <filter string="Người xử lý" name="group_nhan_vien" context="{'group_by':'nhan_vien_xu_ly_id'}"/>
                    <filter string="Trạng thái" name="group_trang_thai" context="{'group_by':'trang_thai'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_van_ban_den" model="ir.actions.act_window">
        <field name="name">Văn bản đến</field>
        <field name="res_model">van_ban_den</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_van_ban_den_search"/>
    </record>
</odoo>
