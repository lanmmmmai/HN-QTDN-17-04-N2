<odoo>
    <record id="module_category_cham_cong_tinh_luong" model="ir.module.category">
        <field name="name">Chấm công / Tính lương</field>
        <field name="description">Phân quyền cho module Chấm công và Tính lương</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_cham_cong_nhan_vien" model="res.groups">
        <field name="name">Chấm công/Lương - Nhân viên</field>
        <field name="category_id" ref="module_category_cham_cong_tinh_luong"/>
    </record>

    <record id="group_cham_cong_nhan_su" model="res.groups">
        <field name="name">Chấm công/Lương - Nhân sự</field>
        <field name="category_id" ref="module_category_cham_cong_tinh_luong"/>
    </record>

    <record id="group_cham_cong_ke_toan" model="res.groups">
        <field name="name">Chấm công/Lương - Kế toán</field>
        <field name="category_id" ref="module_category_cham_cong_tinh_luong"/>
    </record>

    <record id="group_cham_cong_quan_tri" model="res.groups">
        <field name="name">Chấm công/Lương - Quản trị</field>
        <field name="category_id" ref="module_category_cham_cong_tinh_luong"/>
        <field name="implied_ids" eval="[
            (4, ref('group_cham_cong_nhan_vien')),
            (4, ref('group_cham_cong_nhan_su')),
            (4, ref('group_cham_cong_ke_toan'))
        ]"/>
    </record>

    <!-- Legacy English-name aliases — map to the Vietnamese groups above -->
    <record id="group_cham_cong_user" model="res.groups">
        <field name="name">Chấm công/Lương - User</field>
        <field name="category_id" ref="module_category_cham_cong_tinh_luong"/>
        <field name="implied_ids" eval="[(4, ref('group_cham_cong_nhan_vien'))]"/>
    </record>

    <record id="group_cham_cong_hr" model="res.groups">
        <field name="name">Chấm công/Lương - HR</field>
        <field name="category_id" ref="module_category_cham_cong_tinh_luong"/>
        <field name="implied_ids" eval="[(4, ref('group_cham_cong_nhan_su'))]"/>
    </record>

    <record id="group_cham_cong_accountant" model="res.groups">
        <field name="name">Chấm công/Lương - Accountant</field>
        <field name="category_id" ref="module_category_cham_cong_tinh_luong"/>
        <field name="implied_ids" eval="[(4, ref('group_cham_cong_ke_toan'))]"/>
    </record>

    <record id="group_cham_cong_manager" model="res.groups">
        <field name="name">Chấm công/Lương - Manager</field>
        <field name="category_id" ref="module_category_cham_cong_tinh_luong"/>
        <field name="implied_ids" eval="[(4, ref('group_cham_cong_quan_tri'))]"/>
    </record>
</odoo>
