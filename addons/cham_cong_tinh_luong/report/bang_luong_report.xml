<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_bang_luong" model="ir.actions.report">
        <field name="name">Phiếu lương</field>
        <field name="model">bang_luong</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cham_cong_tinh_luong.report_bang_luong_document</field>
        <field name="report_file">cham_cong_tinh_luong.report_bang_luong_document</field>
        <field name="print_report_name">'Phieu_luong_%s_%s_%s' % (object.nhan_vien_id.ho_va_ten or '', object.thang or '', object.nam or '')</field>
    </record>

    <template id="report_bang_luong_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'DejaVu Sans', Arial, sans-serif; font-size: 12px; color: #1a1a1a;">

                        <!-- HEADER -->
                        <div style="text-align: center; border-bottom: 3px solid #0369A1; padding-bottom: 16px; margin-bottom: 20px;">
                            <h1 style="color: #0369A1; font-size: 22px; font-weight: 700; letter-spacing: 2px; margin: 0;">
                                PHIẾU LƯƠNG
                            </h1>
                            <p style="color: #475569; font-size: 13px; margin: 6px 0 0 0;">
                                Kỳ lương: Tháng <strong><span t-esc="o.thang"/></strong> / <strong><span t-esc="o.nam"/></strong>
                            </p>
                            <p style="color: #64748b; font-size: 12px; margin: 6px 0 0 0;">
                                Công thức: Thực lĩnh = (Lương cơ bản / 26) × Số ngày đi làm thực tế + Phụ cấp + Khen thưởng - Kỷ luật
                            </p>
                        </div>

                        <!-- THÔNG TIN NHÂN VIÊN -->
                        <div style="background: #f0f8ff; border-left: 4px solid #0369A1; border-radius: 4px; padding: 12px 16px; margin-bottom: 20px;">
                            <h3 style="color: #0369A1; font-size: 13px; font-weight: 700; margin: 0 0 10px 0; text-transform: uppercase; letter-spacing: 0.5px;">
                                Thông tin nhân viên
                            </h3>
                            <table style="width: 100%; border-collapse: collapse;">
                                <tr>
                                    <td style="width: 30%; padding: 4px 0; color: #475569;">Họ và tên</td>
                                    <td style="padding: 4px 0; font-weight: 600;"><span t-field="o.nhan_vien_id"/></td>
                                    <td style="width: 25%; padding: 4px 0; color: #475569;">Mã nhân viên</td>
                                    <td style="padding: 4px 0; font-weight: 600;"><span t-field="o.ma_nhan_vien"/></td>
                                </tr>
                                <tr>
                                    <td style="padding: 4px 0; color: #475569;">Phòng ban</td>
                                    <td style="padding: 4px 0;"><span t-field="o.phong_ban_id"/></td>
                                    <td style="padding: 4px 0; color: #475569;">Chức vụ</td>
                                    <td style="padding: 4px 0;"><span t-field="o.chuc_vu_id"/></td>
                                </tr>
                                <tr>
                                    <td style="padding: 4px 0; color: #475569;">Ngày lập</td>
                                    <td style="padding: 4px 0;"><span t-field="o.ngay_tao"/></td>
                                    <td style="padding: 4px 0; color: #475569;">Trạng thái</td>
                                    <td style="padding: 4px 0;"><span t-field="o.state"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- BẢNG CHI TIẾT 2 CỘT -->
                        <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                            <tr>
                                <!-- CỘT TRÁI: Tổng hợp công + Khấu trừ -->
                                <td style="width: 50%; vertical-align: top; padding-right: 12px;">
                                    <!-- Tổng hợp công -->
                                    <table style="width: 100%; border-collapse: collapse; border: 1px solid #daeaf6; border-radius: 4px; overflow: hidden;">
                                        <thead>
                                            <tr style="background: #0369A1;">
                                                <th colspan="2" style="color: #fff; font-size: 12px; font-weight: 700; padding: 8px 12px; text-align: left; letter-spacing: 0.3px;">
                                                    TỔNG HỢP CÔNG
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr style="background: #fff;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Tổng ngày công</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right; font-weight: 600;"><span t-field="o.tong_ngay_cong"/></td>
                                            </tr>
                                            <tr style="background: #f8fbfd;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Số ngày đi làm thực tế</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right; font-weight: 600;"><span t-field="o.so_ngay_di_lam"/></td>
                                            </tr>
                                            <tr style="background: #fff;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Tổng giờ làm</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right; font-weight: 600;"><span t-field="o.tong_gio_lam"/></td>
                                            </tr>
                                            <tr style="background: #fff;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Giờ tăng ca</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right; font-weight: 600;"><span t-field="o.tong_gio_tang_ca"/></td>
                                            </tr>
                                            <tr style="background: #f8fbfd;">
                                                <td style="padding: 7px 12px; color: #475569;">Ngày nghỉ</td>
                                                <td style="padding: 7px 12px; text-align: right; font-weight: 600;"><span t-field="o.so_ngay_nghi"/></td>
                                            </tr>
                                        </tbody>
                                    </table>

                                    <!-- Khấu trừ -->
                                    <table style="width: 100%; border-collapse: collapse; border: 1px solid #daeaf6; margin-top: 12px;">
                                        <thead>
                                            <tr style="background: #64748b;">
                                                <th colspan="2" style="color: #fff; font-size: 12px; font-weight: 700; padding: 8px 12px; text-align: left; letter-spacing: 0.3px;">
                                                    KHẤU TRỪ
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr style="background: #fff;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Tiền bảo hiểm</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right; color: #dc2626;"><span t-field="o.tien_bao_hiem"/></td>
                                            </tr>
                                            <tr style="background: #f8fbfd;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Thuế TNCN</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right; color: #dc2626;"><span t-field="o.thue_tncn"/></td>
                                            </tr>
                                            <tr style="background: #fff;">
                                                <td style="padding: 7px 12px; color: #475569;">Khấu trừ khác</td>
                                                <td style="padding: 7px 12px; text-align: right; color: #dc2626;"><span t-field="o.khau_tru_khac"/></td>
                                            </tr>
                                            <tr style="background: #f8fbfd;">
                                                <td style="padding: 7px 12px; color: #475569;">Tổng khấu trừ</td>
                                                <td style="padding: 7px 12px; text-align: right; color: #dc2626;"><span t-field="o.tong_khau_tru"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </td>

                                <!-- CỘT PHẢI: Thu nhập -->
                                <td style="width: 50%; vertical-align: top; padding-left: 12px;">
                                    <table style="width: 100%; border-collapse: collapse; border: 1px solid #daeaf6;">
                                        <thead>
                                            <tr style="background: #0369A1;">
                                                <th colspan="2" style="color: #fff; font-size: 12px; font-weight: 700; padding: 8px 12px; text-align: left; letter-spacing: 0.3px;">
                                                    THU NHẬP
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr style="background: #fff;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Lương cơ bản</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right; font-weight: 600;"><span t-field="o.luong_co_ban"/></td>
                                            </tr>
                                            <tr style="background: #f8fbfd;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Lương theo ngày công</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right;"><span t-field="o.luong_theo_cong"/></td>
                                            </tr>
                                            <tr style="background: #fff;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Đơn giá giờ</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right;"><span t-field="o.don_gia_gio"/></td>
                                            </tr>
                                            <tr style="background: #f8fbfd;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Tiền tăng ca</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right;"><span t-field="o.tien_tang_ca"/></td>
                                            </tr>
                                            <tr style="background: #fff;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Tổng phụ cấp</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right; font-weight: 600;"><span t-field="o.tong_phu_cap"/></td>
                                            </tr>
                                            <tr style="background: #f8fbfd;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Khen thưởng</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right; font-weight: 600;"><span t-field="o.tong_khen_thuong"/></td>
                                            </tr>
                                            <tr style="background: #fff;">
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; color: #475569;">Kỷ luật</td>
                                                <td style="padding: 7px 12px; border-bottom: 1px solid #f0f4f8; text-align: right; font-weight: 600;"><span t-field="o.tong_ky_luat"/></td>
                                            </tr>
                                            <tr style="background: #f8fbfd;">
                                                <td style="padding: 7px 12px; color: #475569;">Hệ số tăng ca</td>
                                                <td style="padding: 7px 12px; text-align: right;"><span t-field="o.he_so_tang_ca"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>
                        </table>

                        <!-- TỔNG LƯƠNG THỰC NHẬN -->
                        <div style="background: #0369A1; border-radius: 8px; padding: 16px 24px; text-align: center; margin-bottom: 20px;">
                            <div style="color: rgba(255,255,255,0.8); font-size: 12px; margin-bottom: 6px; letter-spacing: 1px; text-transform: uppercase;">
                                Lương thực nhận
                            </div>
                            <div style="color: #fff; font-size: 26px; font-weight: 700;">
                                <span t-esc="'{:,.0f}'.format(o.thuc_linh)"/> VNĐ
                            </div>
                        </div>

                        <!-- CHỮ KÝ -->
                        <table style="width: 100%; border-collapse: collapse; margin-top: 30px;">
                            <tr>
                                <td style="width: 33%; text-align: center; padding: 0 10px;">
                                    <div style="font-weight: 700; font-size: 12px; margin-bottom: 60px;">NGƯỜI LẬP</div>
                                    <div style="border-top: 1px solid #aaa; padding-top: 6px; color: #475569; font-size: 11px;">(Ký và ghi rõ họ tên)</div>
                                </td>
                                <td style="width: 33%; text-align: center; padding: 0 10px;">
                                    <div style="font-weight: 700; font-size: 12px; margin-bottom: 60px;">KẾ TOÁN</div>
                                    <div style="border-top: 1px solid #aaa; padding-top: 6px; color: #475569; font-size: 11px;">(Ký và ghi rõ họ tên)</div>
                                </td>
                                <td style="width: 33%; text-align: center; padding: 0 10px;">
                                    <div style="font-weight: 700; font-size: 12px; margin-bottom: 60px;">NGƯỜI NHẬN</div>
                                    <div style="border-top: 1px solid #aaa; padding-top: 6px; color: #475569; font-size: 11px;">(Ký và ghi rõ họ tên)</div>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
