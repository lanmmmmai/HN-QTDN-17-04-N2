<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_khen_thuong_ky_luat_tree" model="ir.ui.view">
            <field name="name">khen_thuong_ky_luat.tree</field>
            <field name="model">khen_thuong_ky_luat</field>
            <field name="arch" type="xml">
                <tree string="Khen thưởng / kỷ luật">
                    <field name="nhan_vien_id"/>
                    <field name="ma_nhan_vien"/>
                    <field name="loai_quyet_dinh"/>
                    <field name="so_tien"/>
                    <field name="ngay_ap_dung"/>
                    <field name="thang"/>
                    <field name="nam"/>
                    <field name="ghi_chu"/>
                </tree>
            </field>
        </record>

        <record id="view_khen_thuong_ky_luat_form" model="ir.ui.view">
            <field name="name">khen_thuong_ky_luat.form</field>
            <field name="model">khen_thuong_ky_luat</field>
            <field name="arch" type="xml">
                <form string="Khen thưởng / kỷ luật">
                    <sheet>
                        <group>
                            <field name="nhan_vien_id"/>
                            <field name="loai_quyet_dinh"/>
                            <field name="so_tien"/>
                            <field name="ngay_ap_dung"/>
                            <field name="thang" readonly="1"/>
                            <field name="nam" readonly="1"/>
                        </group>
                        <group>
                            <field name="ghi_chu"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_khen_thuong_ky_luat_search" model="ir.ui.view">
            <field name="name">khen_thuong_ky_luat.search</field>
            <field name="model">khen_thuong_ky_luat</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm khen thưởng / kỷ luật">
                    <field name="nhan_vien_id"/>
                    <field name="loai_quyet_dinh"/>
                    <field name="ngay_ap_dung"/>
                    <field name="thang"/>
                    <field name="nam"/>
                    <filter name="filter_reward" string="Khen thưởng" domain="[('loai_quyet_dinh', '=', 'khen_thuong')]"/>
                    <filter name="filter_discipline" string="Kỷ luật" domain="[('loai_quyet_dinh', '=', 'ky_luat')]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter name="group_employee" string="Nhân viên" context="{'group_by': 'nhan_vien_id'}"/>
                        <filter name="group_type" string="Loại" context="{'group_by': 'loai_quyet_dinh'}"/>
                        <filter name="group_month" string="Tháng" context="{'group_by': 'thang'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_khen_thuong_ky_luat" model="ir.actions.act_window">
            <field name="name">Khen thưởng / kỷ luật</field>
            <field name="res_model">khen_thuong_ky_luat</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_khen_thuong_ky_luat_search"/>
        </record>
    </data>
</odoo>
