<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="dashboard_cham_cong_luong_form_view" model="ir.ui.view">
            <field name="name">dashboard.cham.cong.luong.form</field>
            <field name="model">dashboard_cham_cong_luong</field>
            <field name="arch" type="xml">
                <form string="Dashboard quản lý" class="o_cctl_form">
                    <header>
                        <button name="action_refresh_dashboard" type="object" string="Cập nhật dashboard" class="btn-primary"/>
                        <button name="action_open_cham_cong" type="object" string="Xem chấm công"/>
                        <button name="action_open_bang_luong" type="object" string="Xem bảng lương"/>
                        <button name="action_open_canh_bao" type="object" string="Xem cảnh báo"/>
                    </header>
                    <sheet>
                        <div class="o_cctl_dashboard">
                            <div class="o_cctl_dashboard_hero">
                                <div class="o_cctl_form_hero_title">Dashboard quản lý chấm công và tính lương</div>
                                <div class="o_cctl_form_hero_subtitle">
                                    Theo dõi nhanh nhân sự, chấm công, quỹ lương và cảnh báo bất thường theo tháng/năm.
                                </div>
                            </div>
                            <group col="4" class="o_cctl_section o_cctl_section_box o_cctl_section_box_primary" string="Kỳ dashboard">
                                <field name="name"/>
                                <field name="thang"/>
                                <field name="nam"/>
                            </group>
                            <div class="row g-3 o_cctl_stats_grid">
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--info">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-users"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_nhan_vien" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Tổng nhân viên</div>
                                        <div class="text-muted small">Số nhân sự đang có trong hệ thống.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--info">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-calendar-check-o"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_cham_cong" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Bản ghi chấm công</div>
                                        <div class="text-muted small">Tổng số dòng chấm công trong tháng.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--success">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-line-chart"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_ngay_cong" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Tổng ngày công</div>
                                        <div class="text-muted small">Số ngày làm việc thực tế đã ghi nhận.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--success">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-clock-o"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_gio_lam" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Tổng giờ làm</div>
                                        <div class="text-muted small">Tổng thời gian làm việc của kỳ hiện tại.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--success">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-plus-circle"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_gio_tang_ca" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Tổng giờ tăng ca</div>
                                        <div class="text-muted small">Số giờ làm thêm ngoài ca chuẩn.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--warning">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-exclamation-circle"/></div>
                                        <div class="o_cctl_stat_value"><field name="so_luot_di_muon" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Số lượt đi muộn</div>
                                        <div class="text-muted small">Các lần đi muộn đã được ghi nhận.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--danger">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-bed"/></div>
                                        <div class="o_cctl_stat_value"><field name="so_ngay_nghi" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Số ngày nghỉ</div>
                                        <div class="text-muted small">Các ngày nghỉ không có công.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--success">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-money"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_quy_luong" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Tổng quỹ lương</div>
                                        <div class="text-muted small">Tổng chi lương dự kiến của kỳ.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--info">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-shield"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_bao_hiem" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Tổng bảo hiểm</div>
                                        <div class="text-muted small">Tổng chi phí bảo hiểm theo kỳ.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--info">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-gift"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_phu_cap" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Tổng phụ cấp</div>
                                        <div class="text-muted small">Tổng giá trị các khoản phụ cấp.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--warning">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-hourglass-half"/></div>
                                        <div class="o_cctl_stat_value"><field name="bang_luong_da_tinh" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Bảng lương chờ xác nhận</div>
                                        <div class="text-muted small">Số bảng lương đã tính nhưng chưa chốt.</div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 col-xl-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--danger">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-bell"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_canh_bao" nolabel="1" readonly="1"/></div>
                                        <div class="o_cctl_stat_label">Cảnh báo bất thường</div>
                                        <div class="text-muted small">Tổng số cảnh báo AI trong kỳ.</div>
                                    </div>
                                </div>
                            </div>
                            <div class="o_cctl_dashboard_summary">
                                <div class="o_cctl_badge_info">Đã tính <field name="bang_luong_da_tinh" nolabel="1" readonly="1"/></div>
                                <div class="o_cctl_badge_success">Đã xác nhận <field name="bang_luong_xac_nhan" nolabel="1" readonly="1"/></div>
                                <div class="o_cctl_badge_success">Đã thanh toán <field name="bang_luong_da_thanh_toan" nolabel="1" readonly="1"/></div>
                                <div class="o_cctl_badge_warning">Cảnh báo mức cao <field name="so_canh_bao_cao" nolabel="1" readonly="1"/></div>
                                <div class="o_cctl_badge_info">Lượt tăng ca <field name="tong_tang_ca" nolabel="1" readonly="1"/></div>
                            </div>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="dashboard_cham_cong_luong_kanban_view" model="ir.ui.view">
            <field name="name">dashboard.cham.cong.luong.kanban</field>
            <field name="model">dashboard_cham_cong_luong</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_dashboard o_kanban_small_column o_cctl_dashboard">
                    <field name="name"/>
                    <field name="thang"/>
                    <field name="nam"/>
                    <field name="tong_nhan_vien"/>
                    <field name="tong_cham_cong"/>
                    <field name="tong_ngay_cong"/>
                    <field name="tong_gio_lam"/>
                    <field name="tong_gio_tang_ca"/>
                    <field name="tong_tang_ca"/>
                    <field name="so_luot_di_muon"/>
                    <field name="so_ngay_nghi"/>
                    <field name="tong_quy_luong"/>
                    <field name="tong_bao_hiem"/>
                    <field name="tong_phu_cap"/>
                    <field name="bang_luong_da_tinh"/>
                    <field name="bang_luong_xac_nhan"/>
                    <field name="bang_luong_da_thanh_toan"/>
                    <field name="tong_canh_bao"/>
                    <field name="so_canh_bao_cao"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click o_kanban_record">
                                <div class="o_kanban_card_content">
                                    <div class="o_cctl_dashboard_card_header">
                                        <div>
                                            <div class="fw-bold fs-5"><field name="name"/></div>
                                            <div class="text-muted">Kỳ <field name="thang"/>/<field name="nam"/></div>
                                        </div>
                                        <span class="o_cctl_badge_info">Dashboard</span>
                                    </div>
                                    <div class="row g-2 mt-2">
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--info">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-users"/></div>
                                                <div class="o_cctl_stat_value"><field name="tong_nhan_vien" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Nhân viên</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--info">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-calendar-check-o"/></div>
                                                <div class="o_cctl_stat_value"><field name="tong_cham_cong" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Chấm công</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--success">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-line-chart"/></div>
                                                <div class="o_cctl_stat_value"><field name="tong_ngay_cong" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Ngày công</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--success">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-plus-circle"/></div>
                                                <div class="o_cctl_stat_value"><field name="tong_gio_tang_ca" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Giờ tăng ca</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--success">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-hourglass-half"/></div>
                                                <div class="o_cctl_stat_value"><field name="tong_gio_lam" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Giờ làm</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--warning">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-clock-o"/></div>
                                                <div class="o_cctl_stat_value"><field name="so_luot_di_muon" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Đi muộn</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--danger">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-bed"/></div>
                                                <div class="o_cctl_stat_value"><field name="so_ngay_nghi" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Nghỉ</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--success">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-money"/></div>
                                                <div class="o_cctl_stat_value"><field name="tong_quy_luong" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Quỹ lương</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--info">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-gift"/></div>
                                                <div class="o_cctl_stat_value"><field name="tong_phu_cap" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Phụ cấp</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--info">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-shield"/></div>
                                                <div class="o_cctl_stat_value"><field name="tong_bao_hiem" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Bảo hiểm</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--warning">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-check-circle"/></div>
                                                <div class="o_cctl_stat_value"><field name="bang_luong_da_tinh" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Chờ xác nhận</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="o_cctl_stat_card o_cctl_stat_card--danger">
                                                <div class="o_cctl_stat_icon"><i class="fa fa-bell"/></div>
                                                <div class="o_cctl_stat_value"><field name="tong_canh_bao" nolabel="1"/></div>
                                                <div class="o_cctl_stat_label">Bất thường</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="o_cctl_dashboard_summary mt-3">
                                        <div class="o_cctl_badge_info">Bảng lương tính <field name="bang_luong_da_tinh" nolabel="1"/></div>
                                        <div class="o_cctl_badge_success">Xác nhận <field name="bang_luong_xac_nhan" nolabel="1"/></div>
                                        <div class="o_cctl_badge_success">Thanh toán <field name="bang_luong_da_thanh_toan" nolabel="1"/></div>
                                        <div class="o_cctl_badge_warning">Cảnh báo <field name="tong_canh_bao" nolabel="1"/></div>
                                    </div>
                                    <div class="mt-3 d-flex gap-2 flex-wrap">
                                        <button type="object" name="action_refresh_dashboard" class="btn btn-primary btn-sm">Cập nhật</button>
                                        <button type="object" name="action_open_cham_cong" class="btn btn-outline-secondary btn-sm">Chấm công</button>
                                        <button type="object" name="action_open_bang_luong" class="btn btn-outline-secondary btn-sm">Bảng lương</button>
                                        <button type="object" name="action_open_canh_bao" class="btn btn-outline-secondary btn-sm">Cảnh báo</button>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="action_dashboard_cham_cong_luong" model="ir.actions.act_window">
            <field name="name">Dashboard quản lý</field>
            <field name="res_model">dashboard_cham_cong_luong</field>
            <field name="view_mode">kanban,form</field>
            <field name="view_id" ref="dashboard_cham_cong_luong_kanban_view"/>
        </record>

        <record id="action_dashboard_cua_toi" model="ir.actions.act_window">
            <field name="name">Dashboard của tôi</field>
            <field name="res_model">dashboard_cham_cong_luong</field>
            <field name="view_mode">kanban,form</field>
            <field name="view_id" ref="dashboard_cham_cong_luong_kanban_view"/>
            <field name="context">{'dashboard_scope': 'mine'}</field>
        </record>

        <record id="dashboard_cham_cong_luong_record" model="dashboard_cham_cong_luong">
            <field name="name">Dashboard quản lý</field>
            <field name="thang" eval="str(datetime.date.today().month)"/>
            <field name="nam" eval="datetime.date.today().year"/>
        </record>

        <record id="view_cham_cong_graph" model="ir.ui.view">
            <field name="name">cham_cong.graph</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <graph string="Thống kê chấm công" type="bar">
                    <field name="nhan_vien_id" type="row"/>
                    <field name="trang_thai" type="row"/>
                    <field name="ngay_cham_cong" type="col" interval="month"/>
                    <field name="so_gio_lam" type="measure"/>
                    <field name="so_gio_tang_ca" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="view_cham_cong_pivot" model="ir.ui.view">
            <field name="name">cham_cong.pivot</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <pivot string="Thống kê chấm công">
                    <field name="nhan_vien_id" type="row"/>
                    <field name="trang_thai" type="row"/>
                    <field name="ngay_cham_cong" type="col" interval="month"/>
                    <field name="so_gio_lam" type="measure"/>
                    <field name="so_gio_tang_ca" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="action_thong_ke_cham_cong" model="ir.actions.act_window">
            <field name="name">Thống kê Chấm công</field>
            <field name="res_model">cham_cong</field>
            <field name="view_mode">tree,graph,pivot</field>
            <field name="search_view_id" ref="view_cham_cong_search"/>
            <field name="context">{'search_default_filter_confirmed': 1}</field>
        </record>

        <record id="view_bang_luong_graph" model="ir.ui.view">
            <field name="name">bang_luong.graph</field>
            <field name="model">bang_luong</field>
            <field name="arch" type="xml">
                <graph string="Thống kê bảng lương" type="bar">
                    <field name="thang" type="col"/>
                    <field name="nhan_vien_id" type="row"/>
                    <field name="state" type="row"/>
                    <field name="tong_luong" type="measure"/>
                    <field name="tong_phu_cap" type="measure"/>
                    <field name="tien_bao_hiem" type="measure"/>
                    <field name="tong_ngay_cong" type="measure"/>
                    <field name="tong_gio_lam" type="measure"/>
                    <field name="tong_gio_tang_ca" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="view_bang_luong_pivot" model="ir.ui.view">
            <field name="name">bang_luong.pivot</field>
            <field name="model">bang_luong</field>
            <field name="arch" type="xml">
                <pivot string="Phân tích bảng lương">
                    <field name="nhan_vien_id" type="row"/>
                    <field name="state" type="row"/>
                    <field name="thang" type="col"/>
                    <field name="nam" type="col"/>
                    <field name="tong_luong" type="measure"/>
                    <field name="tien_bao_hiem" type="measure"/>
                    <field name="tong_phu_cap" type="measure"/>
                    <field name="tong_ngay_cong" type="measure"/>
                    <field name="tong_gio_lam" type="measure"/>
                </pivot>
            </field>
        </record>

        <record id="action_thong_ke_bang_luong" model="ir.actions.act_window">
            <field name="name">Thống kê Bảng lương</field>
            <field name="res_model">bang_luong</field>
            <field name="view_mode">tree,graph,pivot</field>
            <field name="search_view_id" ref="view_bang_luong_search"/>
        </record>
    </data>
</odoo>
