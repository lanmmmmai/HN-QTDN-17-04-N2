<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_cham_cong_tree" model="ir.ui.view">
            <field name="name">cham_cong.tree</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <tree string="Chấm công" decoration-success="trang_thai == 'di_lam' or trang_thai == 'nua_ngay'" decoration-warning="trang_thai == 'di_muon'" decoration-danger="trang_thai in ('nghi', 'nghi_co_phep', 'nghi_khong_phep')" decoration-info="trang_thai == 'tang_ca'">
                    <field name="nhan_vien_id"/>
                    <field name="ma_nhan_vien"/>
                    <field name="phong_ban_id"/>
                    <field name="chuc_vu_id"/>
                    <field name="ngay_cham_cong"/>
                    <field name="ca_lam_viec"/>
                    <field name="gio_vao"/>
                    <field name="gio_ra"/>
                    <field name="so_ngay_cong"/>
                    <field name="so_gio_lam"/>
                    <field name="so_gio_tang_ca"/>
                    <field name="trang_thai"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_cham_cong_form" model="ir.ui.view">
            <field name="name">cham_cong.form</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <form string="Chấm công" class="o_cctl_form">
                    <header>
                        <button name="action_xac_nhan" type="object" string="Xác nhận" class="btn-primary" attrs="{'invisible': [('state', '!=', 'nhap')]}"/>
                        <button name="action_draft" type="object" string="Đặt về nháp" attrs="{'invisible': [('state', '=', 'nhap')]}"/>
                        <button name="action_huy" type="object" string="Hủy" attrs="{'invisible': [('state', '=', 'huy')]}"/>
                        <field name="state" widget="statusbar" statusbar_visible="nhap,xac_nhan,huy"/>
                    </header>
                    <sheet>
                        <div class="o_cctl_form_shell">
                            <div class="o_cctl_form_hero">
                                <div class="o_cctl_form_hero_title">Thông tin chấm công</div>
                                <div class="o_cctl_form_hero_subtitle">Theo dõi ca làm, thời gian vào ra và trạng thái công của nhân viên.</div>
                            </div>
                            <group col="4" class="o_cctl_section o_cctl_section_box o_cctl_section_box_primary" string="Thông tin nhân viên">
                                <field name="nhan_vien_id"/>
                                <field name="ma_nhan_vien" readonly="1"/>
                                <field name="phong_ban_id" readonly="1"/>
                                <field name="chuc_vu_id" readonly="1"/>
                            </group>
                            <div class="row">
                                <div class="col-12 col-lg-7">
                                    <group col="4" class="o_cctl_section o_cctl_section_box" string="Thông tin chấm công">
                                        <field name="ngay_cham_cong"/>
                                        <field name="ca_lam_viec"/>
                                        <field name="gio_vao"/>
                                        <field name="gio_ra"/>
                                        <field name="so_ngay_cong" readonly="1" class="o_cctl_metric_value"/>
                                        <field name="so_gio_lam" readonly="1" class="o_cctl_metric_value"/>
                                        <field name="so_gio_tang_ca" readonly="1" class="o_cctl_metric_value"/>
                                    </group>
                                </div>
                                <div class="col-12 col-lg-5">
                                    <group col="2" class="o_cctl_section o_cctl_section_box o_cctl_section_box_status" string="Trạng thái công">
                                        <field name="trang_thai"/>
                                        <field name="loai_cong"/>
                                        <field name="ly_do_di_muon"/>
                                    </group>
                                </div>
                            </div>
                            <group class="o_cctl_section o_cctl_section_box" string="Ghi chú">
                                <field name="ghi_chu" nolabel="1"/>
                            </group>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_cham_cong_search" model="ir.ui.view">
            <field name="name">cham_cong.search</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm chấm công">
                    <field name="nhan_vien_id"/>
                    <field name="ngay_cham_cong"/>
                    <field name="trang_thai"/>
                    <filter name="filter_today" string="Hôm nay" domain="[('ngay_cham_cong', '=', context_today())]"/>
                    <filter name="filter_month" string="Tháng này" date="ngay_cham_cong" default_period="this_month"/>
                    <filter name="filter_muon" string="Đi muộn" domain="[('trang_thai', '=', 'di_muon')]"/>
                    <filter name="filter_nghi" string="Nghỉ" domain="[('trang_thai', 'in', ('nghi', 'nghi_co_phep', 'nghi_khong_phep'))]"/>
                    <filter name="filter_tang_ca" string="Tăng ca" domain="[('trang_thai', '=', 'tang_ca')]"/>
                    <filter name="filter_confirmed" string="Đã xác nhận" domain="['|', ('state', '=', 'xac_nhan'), ('state', '=', 'confirmed')]"/>
                    <separator/>
                    <filter name="group_employee" string="Nhân viên" context="{'group_by': 'nhan_vien_id'}"/>
                    <filter name="group_status" string="Trạng thái" context="{'group_by': 'state'}"/>
                    <filter name="group_attendance_status" string="Trạng thái công" context="{'group_by': 'trang_thai'}"/>
                    <filter name="group_day" string="Ngày chấm công" context="{'group_by': 'ngay_cham_cong'}"/>
                    <filter name="group_type" string="Loại công" context="{'group_by': 'loai_cong'}"/>
                </search>
            </field>
        </record>

        <record id="action_cham_cong" model="ir.actions.act_window">
            <field name="name">Chấm công</field>
            <field name="res_model">cham_cong</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="search_view_id" ref="view_cham_cong_search"/>
        </record>

        <record id="view_cham_cong_my_tree" model="ir.ui.view">
            <field name="name">cham_cong.my.tree</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <tree string="Chấm công của tôi" decoration-success="trang_thai == 'di_lam' or trang_thai == 'nua_ngay'" decoration-warning="trang_thai == 'di_muon'" decoration-danger="trang_thai in ('nghi', 'nghi_co_phep', 'nghi_khong_phep')" decoration-info="trang_thai == 'tang_ca'">
                    <field name="ngay_cham_cong"/>
                    <field name="ca_lam_viec"/>
                    <field name="gio_vao"/>
                    <field name="gio_ra"/>
                    <field name="so_ngay_cong"/>
                    <field name="so_gio_lam"/>
                    <field name="so_gio_tang_ca"/>
                    <field name="trang_thai"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_cham_cong_my_form" model="ir.ui.view">
            <field name="name">cham_cong.my.form</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <form string="Chấm công của tôi">
                    <sheet>
                        <group>
                            <field name="nhan_vien_id" readonly="1"/>
                            <field name="ma_nhan_vien" readonly="1"/>
                            <field name="ngay_cham_cong" readonly="1"/>
                            <field name="ca_lam_viec" readonly="1"/>
                            <field name="gio_vao" readonly="1"/>
                            <field name="gio_ra" readonly="1"/>
                            <field name="so_ngay_cong" readonly="1"/>
                            <field name="so_gio_lam" readonly="1"/>
                            <field name="so_gio_tang_ca" readonly="1"/>
                            <field name="trang_thai" readonly="1"/>
                            <field name="state" readonly="1"/>
                            <field name="ghi_chu" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_cham_cong_my_search" model="ir.ui.view">
            <field name="name">cham_cong.my.search</field>
            <field name="model">cham_cong</field>
            <field name="arch" type="xml">
                <search string="Chấm công của tôi">
                    <field name="ngay_cham_cong"/>
                    <field name="trang_thai"/>
                    <filter name="my_today" string="Hôm nay" domain="[('ngay_cham_cong', '=', context_today())]"/>
                    <filter name="my_month" string="Tháng này" date="ngay_cham_cong" default_period="this_month"/>
                    <filter name="my_late" string="Đi muộn" domain="[('trang_thai', '=', 'di_muon')]"/>
                    <filter name="my_absent" string="Nghỉ" domain="[('trang_thai', 'in', ('nghi', 'nghi_co_phep', 'nghi_khong_phep'))]"/>
                    <filter name="my_overtime" string="Tăng ca" domain="[('trang_thai', '=', 'tang_ca')]"/>
                    <filter name="my_confirmed" string="Đã xác nhận" domain="['|', ('state', '=', 'xac_nhan'), ('state', '=', 'confirmed')]"/>
                </search>
            </field>
        </record>

        <record id="action_cham_cong_cua_toi" model="ir.actions.act_window">
            <field name="name">Chấm công của tôi</field>
            <field name="res_model">cham_cong</field>
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="view_cham_cong_my_tree"/>
            <field name="search_view_id" ref="view_cham_cong_my_search"/>
            <field name="domain">[('nhan_vien_id.user_id', '=', uid)]</field>
            <field name="context">{'search_default_my_month': 1}</field>
        </record>
    </data>
</odoo>
