<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bang_luong_tree" model="ir.ui.view">
            <field name="name">bang_luong.tree</field>
            <field name="model">bang_luong</field>
            <field name="arch" type="xml">
                <tree string="Bảng lương" decoration-muted="state == 'nhap' or state == 'draft'" decoration-info="state == 'da_tinh' or state == 'computed'" decoration-success="state == 'xac_nhan' or state == 'confirmed'" decoration-bf="state == 'da_thanh_toan'" decoration-danger="state == 'huy' or state == 'cancel'">
                    <field name="nhan_vien_id" string="Nhân viên" options="{'no_open': True}"/>
                    <field name="thang"/>
                    <field name="nam"/>
                    <field name="so_ngay_di_lam"/>
                    <field name="tong_ngay_cong"/>
                    <field name="tong_gio_lam"/>
                    <field name="tong_gio_tang_ca"/>
                    <field name="luong_co_ban"/>
                    <field name="tong_phu_cap"/>
                    <field name="tong_khen_thuong"/>
                    <field name="tong_ky_luat"/>
                    <field name="tong_khau_tru"/>
                    <field name="tong_luong"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <record id="view_bang_luong_form" model="ir.ui.view">
            <field name="name">bang_luong.form</field>
            <field name="model">bang_luong</field>
            <field name="arch" type="xml">
                <form string="Bảng lương" class="o_cctl_form">
                    <header>
                        <button name="action_tinh_luong" type="object" string="Tính lương" class="btn-primary"
                                attrs="{'invisible': [('state', '!=', 'nhap')]}"
                                groups="cham_cong_tinh_luong.group_cham_cong_ke_toan,cham_cong_tinh_luong.group_cham_cong_quan_tri"/>
                        <button name="action_tinh_lai_luong" type="object" string="Cập nhật lương" class="btn-primary"
                                attrs="{'invisible': [('state', 'in', ['nhap', 'huy'])]}"
                                groups="cham_cong_tinh_luong.group_cham_cong_ke_toan,cham_cong_tinh_luong.group_cham_cong_quan_tri"/>
                        <button name="action_xac_nhan" type="object" string="Xác nhận"
                                attrs="{'invisible': [('state', '!=', 'da_tinh')]}"
                                groups="cham_cong_tinh_luong.group_cham_cong_ke_toan,cham_cong_tinh_luong.group_cham_cong_quan_tri"/>
                        <button name="action_da_thanh_toan" type="object" string="Đã thanh toán"
                                attrs="{'invisible': [('state', '!=', 'xac_nhan')]}"
                                groups="cham_cong_tinh_luong.group_cham_cong_ke_toan,cham_cong_tinh_luong.group_cham_cong_quan_tri"/>
                        <button name="action_draft" type="object" string="Đặt về nháp"
                                attrs="{'invisible': [('state', '=', 'nhap')]}"
                                groups="cham_cong_tinh_luong.group_cham_cong_ke_toan,cham_cong_tinh_luong.group_cham_cong_quan_tri"/>
                        <button name="action_huy" type="object" string="Hủy"
                                attrs="{'invisible': [('state', '=', 'huy')]}"
                                groups="cham_cong_tinh_luong.group_cham_cong_ke_toan,cham_cong_tinh_luong.group_cham_cong_quan_tri"/>
                        <button name="action_in_phieu_luong" type="object" string="Xem/In phiếu lương"
                                attrs="{'invisible': [('state', '=', 'nhap')]}"
                                class="btn-secondary"
                                groups="cham_cong_tinh_luong.group_cham_cong_ke_toan,cham_cong_tinh_luong.group_cham_cong_quan_tri"/>
                        <button name="action_in_phieu_luong" type="object" string="Xem phiếu lương"
                                attrs="{'invisible': [('state', '=', 'nhap')]}"
                                class="btn-primary"
                                groups="cham_cong_tinh_luong.group_cham_cong_nhan_vien"/>
                        <field name="state" widget="statusbar" statusbar_visible="nhap,da_tinh,xac_nhan,da_thanh_toan,huy"/>
                    </header>
                    <sheet>
                        <div class="o_cctl_form_shell">
                            <div class="o_cctl_form_hero o_cctl_form_hero_payroll">
                                <div class="o_cctl_form_hero_title">Bảng lương nhân viên</div>
                                <div class="o_cctl_form_hero_subtitle">Tổng hợp công, thu nhập, khấu trừ và lương thực nhận trong kỳ.</div>
                            </div>
                            <div class="o_cctl_warning_banner alert alert-warning" role="alert" attrs="{'invisible': [('canh_bao', 'in', [False, ''])]}">
                                <field name="canh_bao" nolabel="1" readonly="1"/>
                            </div>
                            <group col="4" class="o_cctl_section o_cctl_section_box o_cctl_section_box_primary" string="Kỳ lương">
                                <field name="nhan_vien_id"/>
                                <field name="ma_nhan_vien" readonly="1"/>
                                <field name="thang"/>
                                <field name="nam"/>
                                <field name="ngay_tao"/>
                                <field name="phong_ban_id" readonly="1"/>
                                <field name="chuc_vu_id" readonly="1"/>
                            </group>
                            <div class="row">
                                <div class="col-12 col-lg-6">
                                    <group col="2" class="o_cctl_section o_cctl_section_box" string="Tổng hợp công">
                                        <field name="so_ngay_di_lam" readonly="1" class="o_cctl_metric_value"/>
                                        <field name="tong_ngay_cong" readonly="1" class="o_cctl_metric_value"/>
                                        <field name="tong_gio_lam" readonly="1" class="o_cctl_metric_value"/>
                                        <field name="tong_gio_tang_ca" readonly="1" class="o_cctl_metric_value"/>
                                        <field name="so_ngay_nghi" readonly="1" class="o_cctl_metric_value"/>
                                    </group>
                                </div>
                                <div class="col-12 col-lg-6">
                                    <group col="2" class="o_cctl_section o_cctl_section_box" string="Thu nhập">
                                        <field name="luong_co_ban" readonly="1" class="o_cctl_salary_total"/>
                                        <field name="luong_theo_cong" readonly="1"/>
                                        <field name="don_gia_gio" readonly="1"/>
                                        <field name="tien_tang_ca" readonly="1"/>
                                        <field name="tong_phu_cap" readonly="1" class="o_cctl_salary_total"/>
                                        <field name="tong_khen_thuong" readonly="1"/>
                                        <field name="tong_ky_luat" readonly="1"/>
                                        <field name="he_so_tang_ca"/>
                                    </group>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12 col-lg-6">
                                    <group col="2" class="o_cctl_section o_cctl_section_box" string="Khấu trừ">
                                        <field name="tien_bao_hiem" readonly="1"/>
                                        <field name="thue_tncn" readonly="1"/>
                                        <field name="khau_tru_khac" readonly="1"/>
                                        <field name="tong_khau_tru" readonly="1" class="o_cctl_salary_total"/>
                                    </group>
                                </div>
                                <div class="col-12 col-lg-6">
                                    <div class="o_cctl_salary_total_box">
                                        <div class="text-muted">Tổng lương thực nhận</div>
                                        <div class="o_cctl_salary_total_value o_cctl_salary_total">
                                            <field name="thuc_linh" readonly="1"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <notebook>
                                <page string="Chi tiết chấm công">
                                    <field name="cham_cong_ids" readonly="1">
                                        <tree decoration-success="trang_thai == 'di_lam' or trang_thai == 'nua_ngay'" decoration-warning="trang_thai == 'di_muon'" decoration-danger="trang_thai in ('nghi', 'nghi_co_phep', 'nghi_khong_phep')" decoration-info="trang_thai == 'tang_ca'">
                                            <field name="nhan_vien_id"/>
                                            <field name="ngay_cham_cong"/>
                                            <field name="gio_vao"/>
                                            <field name="gio_ra"/>
                                            <field name="so_ngay_cong"/>
                                            <field name="so_gio_lam"/>
                                            <field name="so_gio_tang_ca"/>
                                            <field name="trang_thai"/>
                                            <field name="state"/>
                                        </tree>
                                    </field>
                                </page>
                                <page string="Công thức tính">
                                    <group class="o_cctl_section">
                                        <field name="cong_thuc_tinh_luong" nolabel="1" readonly="1"/>
                                    </group>
                                </page>
                                <page string="Cảnh báo">
                                    <group class="o_cctl_section">
                                        <field name="canh_bao" nolabel="1" readonly="1"/>
                                    </group>
                                </page>
                                <page string="Ghi chú">
                                    <field name="ghi_chu" nolabel="1"/>
                                </page>
                            </notebook>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_bang_luong_search" model="ir.ui.view">
            <field name="name">bang_luong.search</field>
            <field name="model">bang_luong</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm bảng lương">
                    <field name="nhan_vien_id"/>
                    <field name="thang"/>
                    <field name="nam"/>
                    <field name="state"/>
                    <filter name="filter_month" string="Tháng này" domain="[('thang_so', '=', context_today().month), ('nam', '=', context_today().year)]"/>
                    <filter name="filter_computed" string="Đã tính" domain="['|', ('state', '=', 'da_tinh'), ('state', '=', 'computed')]"/>
                    <filter name="filter_confirmed" string="Đã xác nhận" domain="['|', ('state', '=', 'xac_nhan'), ('state', '=', 'confirmed')]"/>
                    <filter name="filter_paid" string="Đã thanh toán" domain="[('state', '=', 'da_thanh_toan')]"/>
                    <filter name="filter_high_salary" string="Lương cao" domain="[('tong_luong', '&gt;=', 10000000)]"/>
                    <filter name="filter_low_salary" string="Lương thấp bất thường" domain="[('tong_luong', '&lt;=', 5000000)]"/>
                    <separator/>
                    <filter name="group_employee" string="Nhân viên" context="{'group_by': 'nhan_vien_id'}"/>
                    <filter name="group_month" string="Tháng" context="{'group_by': 'thang'}"/>
                    <filter name="group_year" string="Năm" context="{'group_by': 'nam'}"/>
                    <filter name="group_state" string="Trạng thái" context="{'group_by': 'state'}"/>
                </search>
            </field>
        </record>

        <record id="action_bang_luong" model="ir.actions.act_window">
            <field name="name">Bảng lương</field>
            <field name="res_model">bang_luong</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_bang_luong_search"/>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'sequence': 1, 'view_mode': 'tree', 'view_id': ref('view_bang_luong_tree')}),
                (0, 0, {'sequence': 2, 'view_mode': 'form', 'view_id': ref('view_bang_luong_form')}),
            ]"/>
        </record>

        <!-- Self-service tree: chỉ các cột cần thiết cho nhân viên -->
        <record id="view_bang_luong_cua_toi_tree" model="ir.ui.view">
            <field name="name">bang_luong.cua_toi.tree</field>
            <field name="model">bang_luong</field>
            <field name="arch" type="xml">
                <tree string="Bảng lương của tôi" create="false" edit="false" delete="false"
                      decoration-muted="state == 'nhap' or state == 'draft'"
                      decoration-info="state == 'da_tinh' or state == 'computed'"
                      decoration-success="state == 'xac_nhan' or state == 'confirmed'"
                      decoration-bf="state == 'da_thanh_toan'"
                      decoration-danger="state == 'huy' or state == 'cancel'">
                    <field name="nhan_vien_id" string="Nhân viên" options="{'no_open': True}"/>
                    <field name="thang" string="Tháng"/>
                    <field name="nam" string="Năm"/>
                    <field name="so_ngay_di_lam" string="Ngày công thực tế"/>
                    <field name="tong_gio_lam" string="Giờ làm"/>
                    <field name="luong_co_ban" string="Lương cơ bản"/>
                    <field name="tong_phu_cap" string="Phụ cấp"/>
                    <field name="tong_khen_thuong" string="Thưởng"/>
                    <field name="tong_ky_luat" string="Phạt"/>
                    <field name="tong_khau_tru" string="Khấu trừ"/>
                    <field name="tong_luong" string="Lương thực nhận"/>
                    <field name="state" string="Trạng thái"/>
                </tree>
            </field>
        </record>

        <!-- Self-service form: read-only -->
        <record id="view_bang_luong_cua_toi_form" model="ir.ui.view">
            <field name="name">bang_luong.cua_toi.form</field>
            <field name="model">bang_luong</field>
            <field name="arch" type="xml">
                <form string="Phiếu lương của tôi" create="false" edit="false" delete="false" class="o_cctl_form">
                    <header>
                        <button name="action_in_phieu_luong" type="object"
                                string="Xem phiếu lương" class="btn-primary"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="nhap,da_tinh,xac_nhan,da_thanh_toan"/>
                    </header>
                    <sheet>
                        <div class="o_cctl_dashboard">
                            <!-- Hero -->
                            <div class="o_cctl_dashboard_hero">
                                <div class="o_cctl_form_hero_title">
                                    <i class="fa fa-file-text-o" title="Phiếu lương"/> Phiếu lương
                                    — Tháng <field name="thang" readonly="1" nolabel="1"/>/<field name="nam" readonly="1" nolabel="1"/>
                                </div>
                                <div class="o_cctl_form_hero_subtitle">
                                    <field name="nhan_vien_id" readonly="1" nolabel="1"/>
                                    <span class="mx-2">·</span>
                                    <field name="phong_ban_id" readonly="1" nolabel="1"/>
                                    <span class="mx-2">·</span>
                                    <field name="chuc_vu_id" readonly="1" nolabel="1"/>
                                </div>
                            </div>

                            <!-- Thông tin nhân viên -->
                            <div class="o_cctl_section o_cctl_section_box mt-2">
                                <div class="fw-bold text-primary mb-2">Thông tin nhân viên</div>
                                <div class="row g-2">
                                    <div class="col-6 col-md-3">
                                        <div class="text-muted small">Họ và tên</div>
                                        <div class="fw-semibold"><field name="nhan_vien_id" readonly="1" nolabel="1"/></div>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <div class="text-muted small">Mã nhân viên</div>
                                        <div class="fw-semibold"><field name="ma_nhan_vien" readonly="1" nolabel="1"/></div>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <div class="text-muted small">Phòng ban</div>
                                        <div class="fw-semibold"><field name="phong_ban_id" readonly="1" nolabel="1"/></div>
                                    </div>
                                    <div class="col-6 col-md-3">
                                        <div class="text-muted small">Chức vụ</div>
                                        <div class="fw-semibold"><field name="chuc_vu_id" readonly="1" nolabel="1"/></div>
                                    </div>
                                </div>
                            </div>

                            <!-- Stats cards -->
                            <div class="row g-3 o_cctl_stats_grid mt-1">
                                <div class="col-6 col-md-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--info">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-calendar-check-o" title="Ngày công"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_ngay_cong" readonly="1" nolabel="1"/></div>
                                        <div class="o_cctl_stat_label">Ngày công</div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--info">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-clock-o" title="Giờ làm"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_gio_lam" readonly="1" nolabel="1"/></div>
                                        <div class="o_cctl_stat_label">Giờ làm</div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--warning">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-moon-o" title="Tăng ca"/></div>
                                        <div class="o_cctl_stat_value"><field name="tong_gio_tang_ca" readonly="1" nolabel="1"/></div>
                                        <div class="o_cctl_stat_label">Giờ tăng ca</div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="o_cctl_stat_card o_cctl_stat_card--danger">
                                        <div class="o_cctl_stat_icon"><i class="fa fa-times-circle-o" title="Nghỉ"/></div>
                                        <div class="o_cctl_stat_value"><field name="so_ngay_nghi" readonly="1" nolabel="1"/></div>
                                        <div class="o_cctl_stat_label">Ngày nghỉ</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Thu nhập & Khấu trừ -->
                            <div class="row g-3 mt-1">
                                <div class="col-12 col-lg-6">
                                    <div class="o_cctl_section o_cctl_section_box h-100">
                                        <div class="fw-bold text-primary mb-2">Thu nhập</div>
                                            <table class="table table-sm table-borderless mb-0">
                                                <tbody>
                                                    <tr>
                                                        <td class="text-muted">Lương cơ bản</td>
                                                        <td class="text-end fw-semibold"><field name="luong_co_ban" readonly="1" nolabel="1"/></td>
                                                    </tr>
                                                    <tr>
                                                    <td class="text-muted">Lương theo ngày công</td>
                                                    <td class="text-end"><field name="luong_theo_cong" readonly="1" nolabel="1"/></td>
                                                </tr>
                                                <tr>
                                                    <td class="text-muted">Tiền tăng ca</td>
                                                    <td class="text-end"><field name="tien_tang_ca" readonly="1" nolabel="1"/></td>
                                                </tr>
                                                <tr>
                                                    <td class="text-muted">Tổng phụ cấp</td>
                                                    <td class="text-end"><field name="tong_phu_cap" readonly="1" nolabel="1"/></td>
                                                </tr>
                                                <tr>
                                                    <td class="text-muted">Tổng khen thưởng</td>
                                                    <td class="text-end"><field name="tong_khen_thuong" readonly="1" nolabel="1"/></td>
                                                </tr>
                                                <tr>
                                                    <td class="text-muted">Tổng kỷ luật</td>
                                                    <td class="text-end"><field name="tong_ky_luat" readonly="1" nolabel="1"/></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="col-12 col-lg-6">
                                    <div class="o_cctl_section o_cctl_section_box h-100">
                                        <div class="fw-bold text-primary mb-2">Khấu trừ</div>
                                        <table class="table table-sm table-borderless mb-0">
                                            <tbody>
                                                <tr>
                                                    <td class="text-muted">Bảo hiểm xã hội</td>
                                                    <td class="text-end"><field name="tien_bao_hiem" readonly="1" nolabel="1"/></td>
                                                </tr>
                                                <tr>
                                                    <td class="text-muted">Thuế TNCN</td>
                                                    <td class="text-end"><field name="thue_tncn" readonly="1" nolabel="1"/></td>
                                                </tr>
                                                <tr>
                                                    <td class="text-muted">Khấu trừ khác</td>
                                                    <td class="text-end"><field name="khau_tru_khac" readonly="1" nolabel="1"/></td>
                                                </tr>
                                                <tr>
                                                    <td class="text-muted">Tổng khấu trừ</td>
                                                    <td class="text-end"><field name="tong_khau_tru" readonly="1" nolabel="1"/></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <!-- Tổng lương thực nhận -->
                                <div class="o_cctl_salary_total_box mt-3">
                                <div class="text-muted">Lương thực nhận</div>
                                <div class="o_cctl_salary_total_value o_cctl_salary_total">
                                    <field name="thuc_linh" readonly="1" nolabel="1"/>
                                </div>
                            </div>

                            <!-- Chi tiết chấm công -->
                            <notebook class="mt-3">
                                <page string="Chi tiết chấm công">
                                    <field name="cham_cong_ids" readonly="1">
                                        <tree decoration-success="trang_thai == 'di_lam'"
                                              decoration-warning="trang_thai == 'di_muon'"
                                              decoration-danger="trang_thai == 'nghi'"
                                              decoration-info="trang_thai == 'tang_ca'">
                                            <field name="ngay_cham_cong" string="Ngày"/>
                                            <field name="ca_lam_viec" string="Ca"/>
                                            <field name="gio_vao" string="Giờ vào"/>
                                            <field name="gio_ra" string="Giờ ra"/>
                                            <field name="so_gio_lam" string="Giờ làm"/>
                                            <field name="so_gio_tang_ca" string="Tăng ca"/>
                                            <field name="trang_thai" string="Trạng thái"/>
                                        </tree>
                                    </field>
                                </page>
                                <page string="Ghi chú">
                                    <field name="ghi_chu" readonly="1" nolabel="1"/>
                                </page>
                            </notebook>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_bang_luong_cua_toi" model="ir.actions.act_window">
            <field name="name">Bảng lương của tôi</field>
            <field name="res_model">bang_luong</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_bang_luong_search"/>
            <field name="domain">[('nhan_vien_id.user_id', '=', uid)]</field>
            <field name="context">{'search_default_filter_month': 1}</field>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'sequence': 1, 'view_mode': 'tree', 'view_id': ref('view_bang_luong_cua_toi_tree')}),
                (0, 0, {'sequence': 2, 'view_mode': 'form', 'view_id': ref('view_bang_luong_cua_toi_form')}),
            ]"/>
        </record>

        <record id="action_in_phieu_luong_pdf" model="ir.actions.act_window">
            <field name="name">In phiếu lương PDF</field>
            <field name="res_model">bang_luong</field>
            <field name="view_mode">tree,form</field>
