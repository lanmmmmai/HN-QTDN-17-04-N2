<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhan_vien_form_inherit_cham_cong_tinh_luong" model="ir.ui.view">
            <field name="name">nhan_vien.form.inherit.cham_cong_tinh_luong</field>
            <field name="model">nhan_vien</field>
            <field name="inherit_id" ref="nhan_su.view_nhan_vien_form"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook" position="inside">
                    <page string="Chấm công">
                        <field name="cham_cong_ids">
                            <tree editable="bottom">
                                <field name="ngay_cham_cong"/>
                                <field name="ca_lam_viec"/>
                                <field name="gio_vao"/>
                                <field name="gio_ra"/>
                                <field name="so_gio_lam" readonly="1"/>
                                <field name="so_gio_tang_ca" readonly="1"/>
                                <field name="trang_thai"/>
                                <field name="state"/>
                                <field name="ghi_chu"/>
                            </tree>
                        </field>
                    </page>
                    <page string="Cấu hình lương">
                        <field name="cau_hinh_luong_ids">
                            <tree editable="bottom">
                                <field name="luong_co_ban"/>
                                <field name="tong_phu_cap" readonly="1"/>
                                <field name="ty_le_bao_hiem"/>
                                <field name="ngay_bat_dau"/>
                                <field name="trang_thai"/>
                            </tree>
                        </field>
                    </page>
                    <page string="Bảng lương">
                        <field name="bang_luong_ids">
                            <tree editable="bottom">
                                <field name="thang"/>
                                <field name="nam"/>
                                <field name="tong_ngay_cong" readonly="1"/>
                                <field name="tong_gio_lam" readonly="1"/>
                                <field name="tong_gio_tang_ca" readonly="1"/>
                                <field name="luong_co_ban" readonly="1"/>
                                <field name="tong_phu_cap" readonly="1"/>
                                <field name="tien_bao_hiem" readonly="1"/>
                                <field name="tong_luong" readonly="1"/>
                                <field name="state"/>
                            </tree>
                        </field>
                    </page>
                    <page string="Cảnh báo thông minh">
                        <field name="canh_bao_cham_cong_ids">
                            <tree>
                                <field name="thang"/>
                                <field name="nam"/>
                                <field name="loai_canh_bao"/>
                                <field name="muc_do"/>
                                <field name="state"/>
                                <field name="noi_dung"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
