<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhan_vien_form_inherit_cham_cong_tinh_luong" model="ir.ui.view">
            <field name="name">nhan_vien.form.inherit.cham_cong_tinh_luong</field>
            <field name="model">nhan_vien</field>
            <field name="inherit_id" ref="nhan_su.view_nhan_vien_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_open_cham_cong" class="oe_stat_button" icon="fa-calendar-check-o">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Chấm công</span>
                            </div>
                        </button>
                        <button type="object" name="action_open_bang_luong" class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Bảng lương</span>
                            </div>
                        </button>
                        <button type="object" name="action_open_cau_hinh_luong" class="oe_stat_button" icon="fa-sliders">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Cấu hình lương</span>
                            </div>
                        </button>
                        <button type="object" name="action_open_canh_bao" class="oe_stat_button" icon="fa-exclamation-triangle">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Cảnh báo</span>
                            </div>
                        </button>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
